<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>차티스트 인사이트</title>
<meta name="description" content="알트코인 네비게이션 · 추세전환 · RSI 다이버전스 · 기자모리 · 와이코프 신호를 실시간으로 제공합니다.">
<meta property="og:title" content="차티스트 인사이트">
<meta property="og:description" content="알트코인 네비게이션 · 추세전환 · RSI 다이버전스 · 기자모리 · 와이코프 신호를 실시간으로 제공합니다.">
<meta property="og:type" content="website">
<meta property="og:url" content="https://chartist-insight.com">
<meta property="og:image" content="https://chartist-insight.com/og-image.png">
<meta name="google-site-verification" content="hL9PoQ1kGhUZglEKOXMLVIG8iG-mmZ5PM8-VNtfWsms" />
<meta name="twitter:card" content="summary_large_image">
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32v2.png">
<link rel="apple-touch-icon" sizes="192x192" href="/favicon-192v2.png">
<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512v2.png">
<meta name="twitter:title" content="차티스트 인사이트">
<meta name="twitter:description" content="알트코인 네비게이션 · 추세전환 · RSI 다이버전스 · 기자모리 · 와이코프 신호를 실시간으로 제공합니다.">
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap');
  :root {
    --bg:#0e0e0e;--bg2:#161616;--bg3:#1e1e1e;
    --border:rgba(255,255,255,0.08);--border2:rgba(255,255,255,0.14);
    --gold:#C9A84C;--text:#f0f0f0;--text2:#999;--text3:#555;
    --red:#e05555;--red2:#ff6b6b;--green:#4caf7d;--blue:#4a9eff;
    --orange:#FF8C00;--sky:#29B6F6;
    --warn-bg:rgba(224,85,85,0.12);--warn-border:rgba(224,85,85,0.4);
    --info-bg:rgba(74,158,255,0.08);--info-border:rgba(74,158,255,0.3);
    --req-bg:rgba(201,168,76,0.07);--req-border:rgba(201,168,76,0.45);
    --fs-base:14px;--fs-sm:11px;--fs-md:13px;--fs-lg:15px;
    --pad-input:9px 11px;--pad-section:18px;
    --max-w:900px;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{background:var(--bg);color:var(--text);font-family:'Noto Sans KR',sans-serif;font-size:var(--fs-base);min-height:100vh;padding:0 0 60px;}
  body.large{--fs-base:16px;--fs-sm:13px;--fs-md:15px;--fs-lg:17px;--pad-input:11px 13px;--pad-section:22px;}
  body.large .ticker-name{font-size:15px;}
  body.large .ticker-meta{font-size:13px;}
  body.large .mc-lbl{font-size:12px;}
  body.large .mc-val{font-size:28px;}
  body.large .mc-sub,.mc-desc{font-size:13px;}
  body.large .screen-title{font-size:17px;}
  body.large .screen-updated{font-size:13px;}
  body.large .filter-btn,.date-quick-btn{font-size:13px;}
  /* ★ 수정③: large 모드 탭 폰트 13px로 제한 */
  body.large .tab-btn{font-size:13px;}
  body.large .mc-price{font-size:24px;}
  body.large .fg-value{font-size:26px;}
  body.large .ticker-price{font-size:15px;}
  body.large .ticker-change{font-size:14px;}
  .container{max-width:var(--max-w);margin:0 auto;padding:0 20px;}

  /* ══ 헤더 ══ */
  .site-top-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:0.5px solid var(--border);background:var(--bg);}
  .sth-left{display:flex;align-items:center;gap:8px;}
  .sth-logo-box{width:34px;height:34px;border-radius:8px;background:var(--gold);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#0e0e0e;flex-shrink:0;cursor:pointer;transition:opacity 0.15s;}
  .sth-logo-box:hover{opacity:0.85;}
  .sth-logo-text{cursor:pointer;}
  .sth-logo-text{display:flex;flex-direction:column;gap:1px;}
  .sth-title{font-size:14px;font-weight:700;color:var(--gold);}
  .sth-sub{font-size:9px;color:var(--text3);letter-spacing:0.8px;}
  .sth-right{display:flex;align-items:center;gap:5px;}
  .sth-live{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--text3);margin-right:2px;}
  .sth-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 2s infinite;}
  @keyframes blink{0%,100%{opacity:1;}50%{opacity:0.3;}}
  .sth-btn{display:inline-flex;align-items:center;justify-content:center;gap:4px;padding:7px 10px;border-radius:7px;border:none;color:#fff;font-size:11px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;text-decoration:none;transition:all 0.15s;font-weight:500;white-space:nowrap;}
  .sth-btn:hover{opacity:0.85;transform:translateY(-1px);}
  .sth-btn-youtube{background:#FF0000;}
  .sth-btn-telegram{background:#229ED9;}
  /* ★ 수정⑤: 팬딩 버튼 다크 테마 통일 */
  .sth-btn-fanding{background:rgba(85,88,227,0.15);color:#9b9ef5;border:1.5px solid rgba(85,88,227,0.45);font-weight:700;}
  .sth-btn-fanding:hover{background:rgba(85,88,227,0.25);color:#b8bbff;}
  .sth-btn-icon{background:rgba(255,255,255,0.06);border:0.5px solid rgba(255,255,255,0.12);color:var(--text2);padding:7px 9px;font-size:14px;}
  .sth-btn-text{display:inline;}
  @media(max-width:520px){
    .sth-btn-text{display:none;}
    .sth-btn{padding:7px 9px;}
    .sth-title{font-size:13px;}
    .sth-sub{display:none;}
    .sth-live{display:none;}
    .site-top-header{padding:10px 12px;}
  }

  /* ══ 글자크기/공포탐욕 상단 바 ══ */
  .site-header{text-align:center;padding:16px 16px 10px;max-width:var(--max-w);margin:0 auto;}
  .site-header h1{font-size:18px;font-weight:700;color:var(--gold);letter-spacing:0.3px;margin-bottom:8px;}
  .font-size-bar{display:flex;align-items:center;gap:8px;justify-content:center;margin-bottom:10px;}
  .font-size-label{font-size:11px;color:var(--text3);}
  .fs-toggle{display:flex;gap:4px;}
  .fs-btn{padding:4px 12px;border-radius:6px;border:0.5px solid var(--border2);background:var(--bg3);color:var(--text2);font-size:11px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;transition:all 0.15s;}
  .fs-btn.active{background:rgba(201,168,76,0.12);border-color:var(--gold);color:var(--gold);font-weight:500;}
  .market-bar{display:grid;grid-template-columns:1fr 1fr;gap:8px;max-width:var(--max-w);margin:0 auto;padding:0 20px 12px;}
  .market-card{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;padding:12px 16px;}
  .mc-label{font-size:10px;color:var(--text3);margin-bottom:4px;}
  .mc-price{font-size:20px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--text);margin-bottom:2px;}
  .mc-change{font-size:11px;font-family:'JetBrains Mono',monospace;}
  .mc-change.up{color:var(--green);}.mc-change.dn{color:var(--red);}
  .fg-wrap{display:flex;align-items:center;gap:12px;}
  .fg-gauge{position:relative;width:64px;height:34px;overflow:hidden;flex-shrink:0;}
  .fg-gauge canvas{position:absolute;top:0;left:0;}
  .fg-right{flex:1;}
  .fg-value{font-size:22px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--sky);}
  .fg-label{font-size:11px;color:var(--text3);}

  /* ══ 탭 ══ */
  .tab-nav{display:flex;border-bottom:0.5px solid var(--border2);max-width:var(--max-w);margin:0 auto;}
  /* ★ 수정③: 탭 글자 줄바꿈 허용 + 균일 높이 */
  .tab-btn{
    flex:1;
    padding:8px 4px;
    font-size:12px;
    font-family:'Noto Sans KR',sans-serif;
    font-weight:500;
    color:var(--text3);
    background:transparent;
    border:none;
    cursor:pointer;
    border-bottom:2px solid transparent;
    transition:all 0.15s;
    text-align:center;
    /* ★ 핵심 수정: nowrap 제거 → 줄바꿈 허용 */
    white-space:normal;
    line-height:1.3;
    min-height:44px;
    display:flex;
    align-items:center;
    justify-content:center;
    word-break:keep-all;
  }
  .tab-btn.active{color:var(--gold);border-bottom-color:var(--gold);}
  .tab-content{display:none;padding-top:16px;}
  .tab-content.active{display:block;}

  /* ══ 알트코인/주식 공통 ══ */
  .screen-header{margin-bottom:12px;}
  .screen-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px;}
  .screen-updated{font-size:11px;color:var(--text3);}
  .date-filter-wrap{margin-bottom:12px;}
  .date-filter-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:8px;}
  .date-quick-btn{padding:5px 10px;border-radius:6px;border:0.5px solid var(--border2);background:var(--bg3);color:var(--text2);font-size:11px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;transition:all 0.15s;}
  .date-quick-btn.active{background:rgba(201,168,76,0.12);border-color:var(--gold);color:var(--gold);}
  .calendar-wrap{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;padding:12px;margin-bottom:10px;display:none;}
  .calendar-wrap.show{display:block;}
  .cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
  .cal-nav{background:transparent;border:none;color:var(--text2);font-size:16px;cursor:pointer;padding:4px 8px;}
  .cal-month{font-size:13px;font-weight:500;color:var(--text);}
  .cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
  .cal-dow{font-size:10px;color:var(--text3);text-align:center;padding:4px 0;}
  .cal-day{font-size:11px;text-align:center;padding:6px 2px;border-radius:6px;cursor:pointer;color:var(--text2);transition:all 0.1s;}
  .cal-day.cal-today{color:var(--gold);font-weight:700;}
  .cal-day.cal-selected{background:var(--gold);color:#000;font-weight:700;}
  .cal-day.cal-in-range{background:rgba(201,168,76,0.15);color:var(--text);}
  .cal-day.cal-disabled{color:var(--text3);cursor:default;opacity:0.4;}
  .cal-warn{font-size:11px;color:var(--red2);margin-top:6px;display:none;}
  .cal-warn.show{display:block;}
  .filter-row{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:12px;}
  .filter-btn{padding:6px 12px;border-radius:20px;border:0.5px solid var(--border2);background:var(--bg3);color:var(--text2);font-size:11px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;transition:all 0.15s;}
  .filter-btn.active{background:rgba(201,168,76,0.12);border-color:var(--gold);color:var(--gold);}
  .ticker-list{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;overflow:hidden;}
  .ticker-item{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:0.5px solid var(--border);}
  .ticker-item:last-child{border-bottom:none;}
  .ticker-left{display:flex;flex-direction:column;gap:2px;}
  .ticker-name{font-size:13px;font-weight:500;color:var(--text);}
  .ticker-meta{font-size:11px;color:var(--text3);}
  .ticker-price{font-size:13px;font-family:'JetBrains Mono',monospace;color:var(--gold);}
  .sig-badge{font-size:10px;padding:2px 6px;border-radius:4px;font-weight:500;margin-left:4px;}
  .sig-trend{background:rgba(76,175,125,0.15);color:var(--green);}
  .sig-ma{background:rgba(74,158,255,0.12);color:var(--blue);}
  .sig-rsi{background:rgba(255,140,0,0.15);color:var(--orange);}
  .sig-kiz{background:rgba(224,85,85,0.12);color:var(--red2);}
  .sig-wyc{background:rgba(180,100,255,0.12);color:#b464ff;}
  .empty-box,.loading-box{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;padding:24px;text-align:center;color:var(--text3);font-size:11px;}
  .list-header{display:grid;grid-template-columns:1fr auto auto;gap:0;background:var(--bg3);border:0.5px solid var(--border);border-radius:12px 12px 0 0;padding:8px 14px;margin-bottom:0;}
  .list-header+.ticker-list{border-radius:0 0 12px 12px;border-top:none;}
  .lh-col{font-size:10px;color:var(--text3);cursor:pointer;user-select:none;display:flex;align-items:center;gap:3px;}
  .lh-col.sortable:hover{color:var(--text2);}
  .lh-col.sort-asc::after{content:'▲';font-size:8px;color:var(--gold);}
  .lh-col.sort-desc::after{content:'▼';font-size:8px;color:var(--gold);}
  .lh-price{justify-content:flex-end;min-width:80px;}
  .lh-change{justify-content:flex-end;min-width:72px;}
  .ticker-change{font-size:12px;font-family:'JetBrains Mono',monospace;min-width:72px;text-align:right;}
  .ticker-change.up{color:var(--red2);}.ticker-change.dn{color:var(--blue);}.ticker-change.flat{color:var(--text3);}
  .ticker-right{display:flex;flex-direction:column;align-items:flex-end;gap:2px;}
  .last-updated{font-size:10px;color:var(--text3);margin-top:2px;}

  /* ══ 매크로 탭 ══ */
  .macro-section{margin-bottom:24px;}
  .macro-section-title{font-size:12px;color:var(--text2);letter-spacing:0.5px;margin-bottom:10px;padding-bottom:8px;border-bottom:0.5px solid var(--border);font-weight:500;}
  .macro-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:8px;}
  .macro-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
  .macro-card{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;padding:16px 18px;}
  .mc-lbl{font-size:11px;color:var(--text2);margin-bottom:8px;font-weight:500;}
  .mc-chart{width:100%;height:48px;margin:8px 0 4px;}
  .mc-val{font-size:26px;font-weight:700;font-family:'JetBrains Mono',monospace;color:#fff;letter-spacing:-0.5px;}
  .mc-sub{font-size:12px;margin-top:4px;font-weight:500;}
  .mc-up{color:var(--green);}.mc-dn{color:var(--red);}.mc-neu{color:var(--text3);}
  .mc-desc{font-size:11px;color:var(--text2);margin-top:4px;}
  .macro-tv-wrap{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px;}
  .macro-tv-label{font-size:11px;color:var(--text3);padding:10px 14px;border-bottom:0.5px solid var(--border);letter-spacing:0.3px;}

  /* ══ 경제캘린더 (★ 수정②: 자체 렌더링) ══ */
  .eco-cal-wrap{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;overflow:hidden;margin-bottom:20px;}
  .eco-cal-header{display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-bottom:0.5px solid var(--border);}
  .eco-cal-title{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:6px;}
  .eco-cal-title span{color:var(--gold);}
  .eco-cal-refresh{background:transparent;border:none;color:var(--text3);font-size:12px;cursor:pointer;padding:2px 6px;border-radius:4px;transition:all 0.15s;}
  .eco-cal-refresh:hover{color:var(--gold);background:rgba(201,168,76,0.08);}
  .eco-cal-loading{padding:24px;text-align:center;color:var(--text3);font-size:11px;}
  .eco-cal-error{padding:20px;text-align:center;color:var(--red2);font-size:11px;}
  /* 날짜 구분 헤더 */
  .eco-date-row{background:rgba(255,255,255,0.03);padding:7px 14px;font-size:10px;font-weight:700;color:var(--text3);letter-spacing:0.8px;border-bottom:0.5px solid var(--border);}
  .eco-date-row.eco-today{color:var(--gold);background:rgba(201,168,76,0.05);}
  /* 이벤트 행 */
  .eco-event-row{display:grid;grid-template-columns:52px 1fr 64px 64px 64px;gap:0;padding:9px 14px;border-bottom:0.5px solid var(--border);align-items:center;transition:background 0.1s;}
  .eco-event-row:last-child{border-bottom:none;}
  .eco-event-row:hover{background:rgba(255,255,255,0.02);}
  .eco-time{font-size:11px;font-family:'JetBrains Mono',monospace;color:var(--text3);}
  .eco-impact{display:flex;gap:2px;align-items:center;}
  .eco-star{font-size:9px;color:var(--text3);line-height:1;}
  .eco-star.active{color:var(--gold);}
  .eco-name{font-size:12px;color:var(--text);font-weight:500;padding:0 8px;}
  .eco-val{font-size:11px;font-family:'JetBrains Mono',monospace;text-align:right;padding:0 4px;}
  .eco-val.actual-beat{color:var(--green);font-weight:700;}
  .eco-val.actual-miss{color:var(--red2);font-weight:700;}
  .eco-val.actual-meet{color:var(--text);font-weight:700;}
  .eco-val.forecast{color:var(--text2);}
  .eco-val.previous{color:var(--text3);}
  .eco-val.pending{color:var(--text3);}
  /* 컬럼 헤더 */
  .eco-col-header{display:grid;grid-template-columns:52px 1fr 64px 64px 64px;gap:0;padding:6px 14px;border-bottom:0.5px solid var(--border);background:var(--bg3);}
  .eco-col-lbl{font-size:10px;color:var(--text3);text-align:right;padding:0 4px;}
  .eco-col-lbl:first-child{text-align:left;padding:0;}
  .eco-col-lbl:nth-child(2){text-align:left;padding:0 8px;}
  .eco-col-lbl.eco-col-impact{display:flex;gap:2px;}
  /* 모바일 대응 */
  @media(max-width:520px){
    .eco-event-row{grid-template-columns:44px 1fr 52px 52px 52px;}
    .eco-col-header{grid-template-columns:44px 1fr 52px 52px 52px;}
    .eco-name{font-size:11px;}
    .eco-val{font-size:10px;}
  }

  /* ══ 계산기 ══ */
  .top-header{text-align:center;margin-bottom:20px;padding-bottom:16px;border-bottom:0.5px solid var(--border2);}
  .top-header h1{font-size:17px;font-weight:700;color:var(--gold);margin-bottom:6px;}
  .top-header p{font-size:11px;color:var(--text3);}
  .section{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;padding:var(--pad-section);margin-bottom:12px;}
  .sec-header{display:flex;align-items:center;gap:8px;margin-bottom:14px;padding-bottom:10px;border-bottom:0.5px solid var(--border);}
  .badge{width:22px;height:22px;border-radius:50%;background:var(--bg3);border:0.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--gold);flex-shrink:0;}
  .sec-title{font-size:var(--fs-md);font-weight:700;color:var(--text);}
  .sec-sub{font-size:var(--fs-sm);color:var(--text3);margin-left:2px;}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px;}
  .grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:8px;}
  .grid4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:8px;margin-bottom:8px;}
  .tp-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
  .field{display:flex;flex-direction:column;gap:4px;}
  .field label{font-size:var(--fs-sm);color:var(--text3);display:flex;align-items:center;gap:4px;}
  .req-dot{width:5px;height:5px;border-radius:50%;background:var(--red);display:inline-block;flex-shrink:0;}
  .field input,.field select{background:var(--bg3);border:0.5px solid var(--border2);border-radius:8px;padding:var(--pad-input);color:var(--text);font-family:'JetBrains Mono',monospace;font-size:var(--fs-md);width:100%;transition:border-color 0.15s;-webkit-appearance:none;}
  .field input.required,.field select.required{border-color:var(--req-border);background:var(--req-bg);}
  .field input:focus,.field select:focus{outline:none;border-color:var(--gold);}
  .field input::placeholder{color:var(--text3);font-size:var(--fs-sm);}
  .field input[readonly]{color:var(--gold);font-weight:700;border-color:var(--req-border);background:var(--req-bg);cursor:default;}
  .field .hint{font-size:var(--fs-sm);color:var(--blue);margin-top:2px;font-family:'JetBrains Mono',monospace;line-height:1.4;}
  .field .sub-hint{font-size:var(--fs-sm);color:var(--text3);margin-top:2px;}
  .toggle-row{display:flex;gap:6px;margin-bottom:12px;}
  .toggle-btn{flex:1;padding:9px 8px;border-radius:8px;border:0.5px solid var(--border2);background:var(--bg3);color:var(--text2);font-size:var(--fs-sm);font-family:'Noto Sans KR',sans-serif;cursor:pointer;text-align:center;transition:all 0.15s;font-weight:500;}
  .toggle-btn.active{background:rgba(201,168,76,0.12);border-color:var(--gold);color:var(--gold);}
  .group-box{border:0.5px solid var(--border);border-radius:8px;padding:12px;margin-bottom:8px;background:var(--bg3);}
  .group-title{font-size:var(--fs-sm);font-weight:700;color:var(--gold);margin-bottom:10px;}
  .result-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:0.5px solid var(--border);font-size:var(--fs-md);}
  .result-row:last-child{border-bottom:none;}
  .result-label{color:var(--text2);display:flex;align-items:center;gap:5px;}
  .result-val{font-family:'JetBrains Mono',monospace;font-weight:500;text-align:right;}
  .val-gold{color:var(--gold);}.val-green{color:var(--green);}.val-red{color:var(--red);}.val-white{color:var(--text);}
  .warn-box{background:var(--warn-bg);border:0.5px solid var(--warn-border);border-radius:8px;padding:10px 14px;color:var(--red2);font-size:var(--fs-sm);margin:8px 0;display:none;line-height:1.5;}
  .warn-box.show{display:block;}
  .info-box{background:var(--info-bg);border:0.5px solid var(--info-border);border-radius:8px;padding:8px 12px;color:var(--blue);font-size:var(--fs-sm);margin-bottom:10px;line-height:1.5;}
  .sub-section-label{font-size:var(--fs-sm);color:var(--text3);margin-bottom:8px;margin-top:4px;}
  .method-a-content,.method-b-content{display:none;}
  .method-a-content.show,.method-b-content.show{display:block;}
  .tp-block{border:0.5px solid var(--border);border-radius:8px;padding:10px 12px;margin-bottom:8px;background:var(--bg3);}
  .tp-block-title{font-size:var(--fs-sm);font-weight:700;color:var(--text2);margin-bottom:8px;}
  .rr-row{display:flex;justify-content:space-between;align-items:flex-start;padding:7px 0;border-bottom:0.5px solid var(--border);font-size:var(--fs-md);}
  .rr-val{font-family:'JetBrains Mono',monospace;font-weight:500;text-align:right;color:var(--text);line-height:1.7;font-size:12px;}
  .total-row{border-top:1px solid var(--border2);margin-top:4px;padding-top:10px;display:flex;justify-content:space-between;align-items:center;font-size:var(--fs-md);}
  .total-label{color:var(--green);font-weight:700;}
  .total-val{font-family:'JetBrains Mono',monospace;font-weight:700;font-size:var(--fs-lg);color:var(--green);}
  .tooltip-wrap{position:relative;display:inline-flex;align-items:center;}
  .tooltip-icon{width:14px;height:14px;border-radius:50%;background:var(--bg3);border:0.5px solid rgba(224,85,85,0.4);color:var(--red);font-size:9px;display:inline-flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;font-family:'JetBrains Mono',monospace;}
  .tooltip-box{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:#222;border:0.5px solid var(--border2);border-radius:8px;padding:8px 12px;font-size:11px;color:var(--text2);line-height:1.6;z-index:100;min-width:200px;max-width:280px;white-space:normal;}
  .tooltip-wrap:hover .tooltip-box{display:block;}
  .hidden{display:none !important;}

  /* ══ 비트코인 신호 탭 ══ */
  .signal-list{display:flex;flex-direction:column;gap:10px;}
  /* LONG 카드 */
  .signal-item{
    border-radius:14px;
    padding:16px 18px;
    display:flex;align-items:center;justify-content:space-between;
    position:relative;overflow:hidden;
    border:1px solid;
    transition:transform 0.15s;
  }
  .signal-item:hover{transform:translateY(-1px);}
  .signal-item.sig-long{
    background:linear-gradient(135deg,rgba(224,85,85,0.12) 0%,rgba(224,85,85,0.05) 100%);
    border-color:rgba(224,85,85,0.35);
  }
  .signal-item.sig-short{
    background:linear-gradient(135deg,rgba(74,158,255,0.12) 0%,rgba(74,158,255,0.05) 100%);
    border-color:rgba(74,158,255,0.3);
  }
  /* 좌측 컬러 바 */
  .signal-item::before{
    content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:14px 0 0 14px;
  }
  .signal-item.sig-long::before{background:var(--red2);}
  .signal-item.sig-short::before{background:var(--blue);}
  .signal-left{display:flex;flex-direction:column;gap:6px;}
  .signal-top-row{display:flex;align-items:center;gap:8px;}
  .signal-badge-long{
    background:rgba(224,85,85,0.2);color:var(--red2);
    font-size:12px;font-weight:700;padding:4px 10px;border-radius:6px;
    border:1px solid rgba(224,85,85,0.5);letter-spacing:0.5px;
  }
  .signal-badge-short{
    background:rgba(74,158,255,0.15);color:var(--blue);
    font-size:12px;font-weight:700;padding:4px 10px;border-radius:6px;
    border:1px solid rgba(74,158,255,0.4);letter-spacing:0.5px;
  }
  .signal-tf{
    font-size:10px;color:var(--text3);
    background:rgba(255,255,255,0.06);
    border:0.5px solid var(--border2);
    padding:3px 7px;border-radius:4px;font-family:'JetBrains Mono',monospace;
  }
  .signal-ticker{font-size:12px;color:var(--text2);font-family:'JetBrains Mono',monospace;}
  .signal-desc{font-size:11px;color:var(--text3);line-height:1.5;}
  .signal-right{display:flex;flex-direction:column;align-items:flex-end;gap:4px;}
  .signal-entry-label{font-size:10px;color:var(--text3);}
  .signal-entry{font-size:18px;font-family:'JetBrains Mono',monospace;font-weight:700;color:var(--gold);letter-spacing:-0.5px;}
  .signal-entry.long-color{color:var(--red2);}
  .signal-entry.short-color{color:var(--blue);}
  .signal-time{font-size:11px;color:var(--text3);font-family:'JetBrains Mono',monospace;}
  .signal-empty{
    background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;
    padding:40px;text-align:center;color:var(--text3);font-size:12px;
  }

  /* ══ RSI 블러 페이월 ══ */
  .rsi-blur-wrap{position:relative;}
  .rsi-blur-content{transition:filter 0.3s;}
  .rsi-blur-content.blurred{filter:blur(6px);pointer-events:none;user-select:none;}
  .rsi-paywall{display:none;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;width:300px;}
  .rsi-paywall.show{display:block;}

  /* ══ 공통 페이월 팝업 ══ */
  .paywall-box{background:linear-gradient(135deg,#1a1a1a 0%,#111 100%);border:1px solid rgba(201,168,76,0.25);border-radius:20px;padding:32px 28px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.8),0 0 0 1px rgba(255,255,255,0.03);position:relative;}
  .paywall-close{position:absolute;top:14px;right:16px;width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.1);color:var(--text3);font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.15s;}
  .paywall-close:hover{background:rgba(255,255,255,0.1);color:var(--text);}
  .paywall-icon{width:52px;height:52px;border-radius:50%;background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.3);display:flex;align-items:center;justify-content:center;font-size:22px;margin:0 auto 16px;}
  .paywall-title{font-size:15px;font-weight:700;color:var(--gold);margin-bottom:8px;letter-spacing:0.3px;}
  .paywall-desc{font-size:12px;color:var(--text2);margin-bottom:20px;line-height:1.7;}
  .paywall-input{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:11px 14px;color:var(--text);font-size:18px;font-family:'JetBrains Mono',monospace;text-align:center;letter-spacing:8px;margin-bottom:10px;transition:border-color 0.15s;}
  .paywall-input:focus{outline:none;border-color:rgba(201,168,76,0.5);}
  .paywall-btn{width:100%;background:linear-gradient(135deg,rgba(201,168,76,0.2),rgba(201,168,76,0.1));border:1px solid rgba(201,168,76,0.4);border-radius:10px;padding:11px;color:var(--gold);font-size:13px;font-weight:700;cursor:pointer;font-family:'Noto Sans KR',sans-serif;transition:all 0.15s;letter-spacing:0.5px;}
  .paywall-btn:hover{background:linear-gradient(135deg,rgba(201,168,76,0.3),rgba(201,168,76,0.15));border-color:var(--gold);}
  .paywall-error{font-size:11px;color:var(--red2);margin-top:8px;display:none;}
  .paywall-error.show{display:block;}
  .paywall-sub{margin-top:16px;padding-top:14px;border-top:0.5px solid rgba(255,255,255,0.06);}
  .paywall-sub a{font-size:11px;color:rgba(201,168,76,0.7);text-decoration:none;transition:color 0.15s;}
  .paywall-sub a:hover{color:var(--gold);}

  /* ══ 매뉴얼 팝업 ══ */
  .manual-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.8);backdrop-filter:blur(3px);z-index:2000;align-items:center;justify-content:center;padding:16px;}
  .manual-overlay.show{display:flex;}
  .manual-box{background:var(--bg2);border:0.5px solid rgba(201,168,76,0.2);border-radius:20px;width:100%;max-width:480px;max-height:85vh;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 24px 80px rgba(0,0,0,0.8);}
  .manual-header{display:flex;align-items:center;justify-content:space-between;padding:18px 20px;border-bottom:0.5px solid var(--border);}
  .manual-title{font-size:14px;font-weight:700;color:var(--gold);}
  .manual-close{width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.05);border:0.5px solid rgba(255,255,255,0.1);color:var(--text3);font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .manual-tabs{display:flex;border-bottom:0.5px solid var(--border);overflow-x:auto;scrollbar-width:none;}
  .manual-tabs::-webkit-scrollbar{display:none;}
  .manual-tab{flex-shrink:0;padding:10px 14px;font-size:11px;font-family:'Noto Sans KR',sans-serif;color:var(--text3);background:transparent;border:none;cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all 0.15s;}
  .manual-tab.active{color:var(--gold);border-bottom-color:var(--gold);}
  .manual-body{flex:1;overflow-y:auto;padding:20px;}
  .manual-section{display:none;}
  .manual-section.active{display:block;}
  .manual-section-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:14px;}
  .manual-block{margin-bottom:18px;}
  .manual-block-title{font-size:12px;font-weight:700;color:var(--gold);margin-bottom:6px;display:flex;align-items:center;gap:6px;}
  .manual-block-body{font-size:12px;color:var(--text2);line-height:1.8;}
  .manual-badge-lock{font-size:10px;background:rgba(201,168,76,0.12);border:0.5px solid rgba(201,168,76,0.3);color:var(--gold);padding:2px 6px;border-radius:4px;cursor:pointer;text-decoration:none;}
  .manual-badge-lock:hover{background:rgba(201,168,76,0.2);}
  .manual-divider{height:0.5px;background:var(--border);margin:16px 0;}
  .manual-cta{background:linear-gradient(135deg,rgba(201,168,76,0.08),rgba(201,168,76,0.04));border:1px solid rgba(201,168,76,0.2);border-radius:14px;padding:20px;text-align:center;margin-top:8px;}
  .manual-cta-title{font-size:14px;font-weight:700;color:var(--gold);margin-bottom:10px;}
  .manual-cta-desc{font-size:12px;color:var(--text2);line-height:1.8;margin-bottom:16px;}
  .manual-cta-btn{display:inline-block;background:var(--gold);color:#0e0e0e;font-size:13px;font-weight:700;padding:11px 24px;border-radius:10px;text-decoration:none;transition:all 0.15s;}
  .manual-cta-btn:hover{opacity:0.85;}
  .manual-footer{padding:14px 20px;border-top:0.5px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
  .manual-no-show{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--text3);cursor:pointer;}
  .manual-no-show input{cursor:pointer;accent-color:var(--gold);}

  /* ══ 비트코인 페이월 오버레이 ══ */
  .btc-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.75);backdrop-filter:blur(2px);z-index:1000;align-items:center;justify-content:center;}

  /* ══ 푸터 ══ */
  .site-footer{border-top:0.5px solid var(--border);padding:28px 20px;text-align:center;margin-top:48px;}
  .sf-links{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;margin-bottom:16px;}
  .sf-note{font-size:11px;color:rgba(255,255,255,0.75);line-height:1.8;max-width:560px;margin:0 auto 6px;}
  .sf-source{font-size:10px;color:rgba(255,255,255,0.45);}

  @media(max-width:520px){.grid4{grid-template-columns:1fr 1fr;}.grid3{grid-template-columns:1fr 1fr;}.tooltip-box{left:0;transform:none;}.sth-sub{display:none;}.macro-grid{grid-template-columns:1fr 1fr;}}
  @keyframes flashUp{0%{background:rgba(76,175,125,0.25);}100%{background:transparent;}}
  @keyframes flashDn{0%{background:rgba(224,85,85,0.25);}100%{background:transparent;}}
  .flash-up{animation:flashUp 0.6s ease-out;}
  .flash-dn{animation:flashDn 0.6s ease-out;}
  .ptr-bar{position:fixed;top:0;left:0;right:0;height:3px;background:var(--gold);transform:scaleX(0);transform-origin:left;transition:transform 0.3s;z-index:9999;display:none;}
  .ptr-bar.show{display:block;}

  /* ══ BTC 탭 블러 ══ */
  .btc-blur-wrap{position:relative;}
  .btc-blur-content{transition:filter 0.3s;}
  .btc-blur-content.blurred{filter:blur(6px);pointer-events:none;user-select:none;}
  .btc-paywall-inline{display:none;position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10;width:300px;}
  .btc-paywall-inline.show{display:block;}

  /* ══ BTC 신호 팝업 (슬라이드인) ══ */
  .btc-popup{position:fixed;bottom:20px;right:16px;z-index:3000;width:260px;background:linear-gradient(135deg,#1a1a1a,#111);border:1px solid rgba(201,168,76,0.3);border-radius:16px;padding:16px;box-shadow:0 8px 32px rgba(0,0,0,0.7);transform:translateY(120px);opacity:0;transition:transform 0.35s cubic-bezier(0.34,1.56,0.64,1),opacity 0.3s ease;pointer-events:none;}
  .btc-popup.show{transform:translateY(0);opacity:1;pointer-events:auto;}
  .btc-popup-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
  .btc-popup-title{font-size:11px;color:var(--text3);letter-spacing:0.5px;}
  .btc-popup-close{width:22px;height:22px;border-radius:50%;background:rgba(255,255,255,0.06);border:none;color:var(--text3);font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;}
  .btc-popup-body{text-align:center;}
  .btc-popup-dir{font-size:13px;font-weight:700;padding:6px 14px;border-radius:8px;display:inline-block;margin-bottom:8px;}
  .btc-popup-dir.long{background:rgba(224,85,85,0.2);color:var(--red2);border:1px solid rgba(224,85,85,0.4);}
  .btc-popup-dir.short{background:rgba(74,158,255,0.15);color:var(--blue);border:1px solid rgba(74,158,255,0.35);}
  .btc-popup-entry{font-size:20px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--gold);}
  .btc-popup-tf{font-size:10px;color:var(--text3);margin-top:4px;}
  .btc-popup-blur{filter:blur(5px);user-select:none;font-size:18px;font-weight:700;color:var(--gold);}
  .btc-popup-lock{font-size:12px;color:var(--text2);margin-top:6px;cursor:pointer;}
  .btc-popup-lock:hover{color:var(--gold);}

  /* ══ 소리 설정 팝업 ══ */
  .sound-overlay{display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);backdrop-filter:blur(3px);z-index:2500;align-items:center;justify-content:center;padding:16px;}
  .sound-overlay.show{display:flex;}
  .sound-box{background:var(--bg2);border:0.5px solid rgba(201,168,76,0.2);border-radius:20px;width:100%;max-width:320px;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.8);}
  .sound-box-title{font-size:14px;font-weight:700;color:var(--gold);margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;}
  .sound-toggle-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:16px;border-bottom:0.5px solid var(--border);}
  .sound-toggle-label{font-size:13px;color:var(--text);}
  .sound-switch{position:relative;width:44px;height:24px;cursor:pointer;}
  .sound-switch input{opacity:0;width:0;height:0;position:absolute;}
  .sound-slider{position:absolute;top:0;left:0;right:0;bottom:0;background:var(--bg3);border-radius:24px;transition:0.3s;border:0.5px solid var(--border2);}
  .sound-slider::before{content:'';position:absolute;width:18px;height:18px;border-radius:50%;background:#fff;top:3px;left:3px;transition:0.3s;}
  .sound-switch input:checked+.sound-slider{background:rgba(201,168,76,0.3);border-color:var(--gold);}
  .sound-switch input:checked+.sound-slider::before{transform:translateX(20px);background:var(--gold);}
  .sound-vol-row{margin-bottom:16px;}
  .sound-vol-label{font-size:11px;color:var(--text3);margin-bottom:8px;display:flex;justify-content:space-between;}
  .sound-vol-slider{width:100%;-webkit-appearance:none;height:4px;border-radius:4px;background:var(--bg3);outline:none;border:0.5px solid var(--border2);}
  .sound-vol-slider::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:var(--gold);cursor:pointer;}
  .sound-type-row{margin-bottom:20px;}
  .sound-type-label{font-size:11px;color:var(--text3);margin-bottom:8px;}
  .sound-type-btns{display:flex;gap:6px;}
  .sound-type-btn{flex:1;padding:8px 4px;border-radius:8px;border:0.5px solid var(--border2);background:var(--bg3);color:var(--text2);font-size:11px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;text-align:center;transition:all 0.15s;}
  .sound-type-btn.active{background:rgba(201,168,76,0.12);border-color:var(--gold);color:var(--gold);}
  .sound-preview-row{display:flex;gap:6px;margin-top:6px;}
  .sound-preview-btn{flex:1;padding:6px;border-radius:6px;border:0.5px solid var(--border);background:var(--bg3);color:var(--text3);font-size:10px;cursor:pointer;text-align:center;transition:all 0.15s;}
  .sound-preview-btn:hover{border-color:var(--gold);color:var(--gold);}
  .sound-close-btn{width:100%;padding:10px;border-radius:10px;border:0.5px solid var(--border2);background:var(--bg3);color:var(--text2);font-size:13px;font-family:'Noto Sans KR',sans-serif;cursor:pointer;transition:all 0.15s;}
  .sound-close-btn:hover{border-color:var(--gold);color:var(--gold);}

  /* ══ 크립토 버블맵 ══ */
  .bubble-wrap{background:var(--bg2);border:0.5px solid var(--border);border-radius:12px;overflow:hidden;margin-top:20px;}
  .bubble-label{font-size:11px;color:var(--text3);padding:10px 14px;border-bottom:0.5px solid var(--border);}

  /* ══ 매매일지 ══ */
  .journal-login-wrap{display:flex;align-items:center;justify-content:center;min-height:200px;}
  .journal-login-box{background:var(--bg2);border:0.5px solid rgba(201,168,76,0.2);border-radius:20px;padding:32px 28px;width:100%;max-width:320px;text-align:center;}
  .journal-login-title{font-size:15px;font-weight:700;color:var(--gold);margin-bottom:6px;}
  .journal-login-desc{font-size:12px;color:var(--text2);margin-bottom:20px;line-height:1.7;}
  .journal-input{width:100%;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:10px;padding:10px 14px;color:var(--text);font-size:13px;font-family:'JetBrains Mono',monospace;margin-bottom:8px;transition:border-color 0.15s;}
