function drawMiniChart(canvasId,data,color){var canvas=document.getElementById(canvasId);if(!canvas||!data||data.length<2)return;var ctx=canvas.getContext('2d');var w=canvas.offsetWidth||260;var h=48;canvas.width=w;canvas.height=h;ctx.clearRect(0,0,w,h);var mn=Math.min.apply(null,data);var mx=Math.max.apply(null,data);var range=mx-mn||1;var pts=data.map(function(v,i){return{x:i/(data.length-1)*w,y:h-(v-mn)/range*(h-6)-3};});ctx.beginPath();ctx.moveTo(pts[0].x,h);pts.forEach(function(p){ctx.lineTo(p.x,p.y);});ctx.lineTo(pts[pts.length-1].x,h);ctx.closePath();ctx.fillStyle=color.replace('1)','0.12)');ctx.fill();ctx.beginPath();ctx.moveTo(pts[0].x,pts[0].y);pts.forEach(function(p){ctx.lineTo(p.x,p.y);});ctx.strokeStyle=color;ctx.lineWidth=1.5;ctx.stroke();}

