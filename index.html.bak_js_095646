  var dateOrder=[];
  events.forEach(function(ev){
    if(!grouped[ev.date]){grouped[ev.date]=[];dateOrder.push(ev.date);}
    grouped[ev.date].push(ev);
  });

  // 오늘 날짜 (KST)
  var nowKst=new Date(Date.now()+9*60*60*1000);
  var todayMM=String(nowKst.getUTCMonth()+1).padStart(2,'0');
  var todayDD=String(nowKst.getUTCDate()).padStart(2,'0');
  var todayYYYY=nowKst.getUTCFullYear();
  var todayStr=todayMM+'-'+todayDD+'-'+todayYYYY;

  var html='';
  dateOrder.forEach(function(date){
    var isToday=(date===todayStr);
    html+='<div class="eco-date-row'+(isToday?' eco-today':'')+'">'+fmtEcoDate(date,isToday)+'</div>';
    grouped[date].forEach(function(ev){
      var actualCls=getActualClass(ev.actual,ev.forecast);
      html+='<div class="eco-event-row">';
      html+='<div class="eco-time">'+(ev.kst_time||'—')+'</div>';
      html+='<div class="eco-impact"><span class="eco-star active">★</span><span class="eco-star active">★</span><span class="eco-star active">★</span></div>';
      html+='<div class="eco-name">'+escapeHtml(ev.title||'')+'</div>';
      html+='<div class="eco-val '+(ev.actual?actualCls:'pending')+'">'+(ev.actual||'—')+'</div>';
      html+='<div class="eco-val forecast">'+(ev.forecast||'—')+'</div>';
      html+='<div class="eco-val previous">'+(ev.previous||'—')+'</div>';
      html+='</div>';
    });
  });

  bodyEl.innerHTML=html;
}

function fmtEcoDate(dateStr,isToday){
  // FF 날짜: "05-28-2026" (MM-DD-YYYY)
  try{
    var parts=dateStr.split('-');
    if(parts.length!==3) return dateStr+(isToday?' (오늘)':'');
    var m=parseInt(parts[0]);
    var d=parseInt(parts[1]);
    var y=parseInt(parts[2]);
    var days=['일','월','화','수','목','금','토'];
    var dObj=new Date(y,m-1,d);
    var dow=days[dObj.getDay()];
    return y+'년 '+m+'월 '+d+'일 ('+dow+')'+(isToday?' · 오늘':'');
  }catch(e){return dateStr;}
}

function getActualClass(actual,forecast){
  if(!actual||!forecast) return 'actual-meet';
  var a=parseFloat(actual.replace(/[^0-9.-]/g,''));
  var f=parseFloat(forecast.replace(/[^0-9.-]/g,''));
  if(isNaN(a)||isNaN(f)) return 'actual-meet';
  var diff=((a-f)/Math.abs(f||1))*100;
  if(diff>1) return 'actual-beat';
  if(diff<-1) return 'actual-miss';
  return 'actual-meet';
}

function escapeHtml(str){
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

